server {
    listen       ${PORT};
    server_name  _;

    root   /usr/share/nginx/html;
    index  dashboard.html;

    # Serve the dashboard at "/" and don't cache it, so a refresh always
    # shows the latest digest run.
    location / {
        try_files $uri $uri/ =404;
        add_header Cache-Control "no-cache";
    }
}
